<launch>
    <arg name="mode" default="1" />

    <node pkg="robot_localization" type="ekf_localization_node" name="ekf_se" clear_params="true">
        <rosparam command="load" file="$(find sensor_fusion_kalman)/config/ekf_odom.yaml" if="$(eval arg('mode') == 1)" />
        <rosparam command="load" file="$(find sensor_fusion_kalman)/config/ekf_odom_imu.yaml" if="$(eval arg('mode') == 2)" />
        <rosparam command="load" file="$(find sensor_fusion_kalman)/config/ekf_odom_imu_gps.yaml" if="$(eval arg('mode') == 3)" />
        
        <remap from="odometry/filtered" to="/odometry/filtered_tcc" />
    </node>

    <node pkg="robot_localization" type="navsat_transform_node" name="navsat_transform" clear_params="true" if="$(eval arg('mode') == 3)">
        <param name="magnetic_declination_radians" value="0"/>
        <param name="yaw_offset" value="0"/>
        <param name="zero_altitude" value="true"/>
        
        <remap from="/imu/data" to="/imu/data" />
        <remap from="/gps/fix" to="/navsat/fix" />
        <remap from="/odometry/gps" to="/gps/odom" />
    </node>

    <node pkg="sensor_fusion_kalman" type="metrics_evaluator.py" name="metrics_evaluator" output="screen" />
</launch>
